# NAS Application Configuration
# Copy this file to .env and update the values. `.env` is gitignored.

# ─────────────────────────────────────────────────────────────
# IMPORTANT — path safety
# ─────────────────────────────────────────────────────────────
# Relative paths below resolve from the working directory at runtime.
# `go run ./cmd/server` → cwd is `backend/`.
# `./backend/server.exe`  from repo root → cwd is the repo root.
# `docker compose up`     → cwd is whichever shell ran it.
#
# Prefer ABSOLUTE paths or paths that stay UNDER the project (`./data/...`,
# `./tmp/...`). If a relative path starts with `../`, data lands OUTSIDE the
# project. The backend logs a `slog.Warn` at startup when this happens but
# does NOT refuse to start, so check the log line `path resolves outside cwd`.
#
# Past footgun: stray `nas-data/`, `nas-admin-data/`, `nas-db/` siblings to
# the repo. They've been moved into `tmp/recovered-from-parent/` for review.

# ─────────────────────────────────────────────────────────────
# Secrets (required in production)
# ─────────────────────────────────────────────────────────────
PRIVATE_KEY=smoke-test-key-please-replace-in-production
ADMIN_PASSWORD=smoke-admin-please-replace

# ─────────────────────────────────────────────────────────────
# Network
# ─────────────────────────────────────────────────────────────
PORT=7777
HOST=0.0.0.0
AUTH_TYPE=both                # both | local | oauth
JWT_EXPIRY=168h
CORS_ORIGIN=*

# ─────────────────────────────────────────────────────────────
# Storage roots
# ─────────────────────────────────────────────────────────────
# `docker compose` mounts these under the container (see docker-compose.yml).
DATA_PATH=./data

# Used by `server.exe` / `go run ./cmd/server` directly.
# Keep under the project root unless you explicitly want them elsewhere.
NAS_DATA_DIR=./data/nas
NAS_ADMIN_DATA_DIR=./data/nas-admin
NAS_TEMP_DIR=./data/tmp
DB_PATH=./data/db/nas.sqlite
FRONTEND_DIR=./frontend/build

# ─────────────────────────────────────────────────────────────
# Limits
# ─────────────────────────────────────────────────────────────
MAX_FILE_SIZE=50gb            # supports kb / mb / gb suffix
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=false
PASSWORD_REQUIRE_LOWERCASE=false
PASSWORD_REQUIRE_NUMBER=false
PASSWORD_REQUIRE_SPECIAL=false
MEDIA_LIB_LIMIT=5000

# ─────────────────────────────────────────────────────────────
# OAuth (optional — leave blank to disable)
# ─────────────────────────────────────────────────────────────
# DISCORD_CLIENT_ID=
# DISCORD_CLIENT_SECRET=
# DISCORD_REDIRECT_URI=
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=

# ─────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────
NODE_ENV=development          # development | production
TZ=UTC
